# ------------------------------------------------------------------------------
# 1. CORE APPLICATION CONFIGURATION
# ------------------------------------------------------------------------------
APP_NAME=CreativeUniverse
APP_ENV=production
APP_KEY=base64:9kUKJ0Bi8gBbFHMzI4t1fiiqaCIoP7Vlw0xAGwtu/y4=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://creative.doran.id

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ------------------------------------------------------------------------------
# 2. LOGGING SYSTEM
# ------------------------------------------------------------------------------
LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ------------------------------------------------------------------------------
# 3. DATABASE CONFIGURATION (cPanel MySQL)
# ------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=creativedoran_creativeuniverse
DB_USERNAME=creativedoran_root
DB_PASSWORD=doran2026

# ------------------------------------------------------------------------------
# 4. SESSION & CACHE CONFIGURATION
# ------------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=

# ------------------------------------------------------------------------------
# 5. MAIL SERVICES (Default: Log Channel)
# ------------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

